# Application
APP_NAME=CoreDent API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Security - CHANGE IN PRODUCTION
SECRET_KEY=generate-with-python-c-secrets-token-urlsafe-32-or-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Comma separated origins
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000,https://YOUR_FRONTEND_DOMAIN.com

# SECURITY: Allowed hosts (comma separated) - NO WILDCARDS IN PRODUCTION
ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_BACKEND_DOMAIN.com

# Frontend URL
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_EMAIL
SMTP_PASSWORD=YOUR_SMTP_APP_PASSWORD
SMTP_FROM=noreply@coredent.com
SMTP_FROM_NAME=CoreDent PMS

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME
AWS_REGION=us-east-1

# Redis Configuration (Optional)
REDIS_URL=redis://YOUR_REDIS_HOST:6379/0
REDIS_CACHE_TTL=3600

# Sentry (Optional - Recommended for Production)
SENTRY_DSN=

# CAPTCHA Configuration (Required for Online Booking)
# Get keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
HCAPTCHA_SITE_KEY=

# Webhook Security (Recommended for Production)
STRIPE_WEBHOOK_IP_WHITELIST_ENABLED=true
STRIPE_WEBHOOK_HMAC_SECRET=

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# HIPAA Compliance - Updated to 12 chars per HIPAA recommendations
AUDIT_LOG_ENABLED=True
SESSION_TIMEOUT_MINUTES=30
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True
PASSWORD_EXPIRE_DAYS=90
