# Application
APP_NAME=CoreDent API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://coredent:coredent123@localhost:5432/coredent_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Security - CHANGE IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Comma separated origins
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# SECURITY: Allowed hosts (comma separated) - NO WILDCARDS IN PRODUCTION
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@coredent.com
SMTP_FROM_NAME=CoreDent PMS

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=coredent-files
AWS_REGION=us-east-1

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Sentry (Optional)
SENTRY_DSN=

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# HIPAA Compliance - Updated to 12 chars per HIPAA recommendations
AUDIT_LOG_ENABLED=True
SESSION_TIMEOUT_MINUTES=30
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True
PASSWORD_EXPIRE_DAYS=90
