# Staging Environment Configuration
# Copy this file to .env.staging and update with your values

# API Configuration
VITE_API_BASE_URL=https://api-staging.coredent.com

# Environment
VITE_ENV=staging

# Feature Flags
VITE_ENABLE_DEMO_MODE=true
VITE_ENABLE_ANALYTICS=true

# Development Mode
VITE_DEV_BYPASS_AUTH=false

# Monitoring
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=staging
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

# Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# External Services (use test keys)
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx

# Application
VITE_APP_NAME=CoreDent PMS (Staging)
VITE_APP_VERSION=1.0.0-staging
VITE_SUPPORT_EMAIL=staging@coredent.com

# Security
VITE_ENABLE_CSRF=true
VITE_SESSION_TIMEOUT=7200000

# Performance
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true
