# CoreDent PMS - Environment Variables
# Copy this file to .env and fill in your values

# ==============================================
# API Configuration
# ==============================================

# Backend API URL
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ==============================================
# Feature Flags
# ==============================================

# Enable demo mode with mock data (development only)
VITE_ENABLE_DEMO_MODE=true

# Enable development mode authentication bypass
VITE_DEV_BYPASS_AUTH=false

# ==============================================
# Analytics
# ==============================================

# Enable analytics tracking
VITE_ANALYTICS_ENABLED=false

# PostHog API Key (optional)
VITE_POSTHOG_KEY=

# PostHog Host (optional, defaults to PostHog cloud)
VITE_POSTHOG_HOST=https://app.posthog.com

# ==============================================
# Error Monitoring
# ==============================================

# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Sentry Environment
VITE_SENTRY_ENVIRONMENT=development

# ==============================================
# Payment Processing
# ==============================================

# Stripe Publishable Key
VITE_STRIPE_PUBLISHABLE_KEY=

# Square Application ID
VITE_SQUARE_APPLICATION_ID=

# Square Location ID
VITE_SQUARE_LOCATION_ID=

# ==============================================
# Feature Toggles
# ==============================================

# Enable push notifications
VITE_ENABLE_PUSH_NOTIFICATIONS=false

# Enable email notifications
VITE_ENABLE_EMAIL_NOTIFICATIONS=false

# Enable SMS notifications
VITE_ENABLE_SMS_NOTIFICATIONS=false

# Enable 2FA/MFA
VITE_ENABLE_MFA=false

# ==============================================
# Third-Party Integrations
# ==============================================

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=

# Apple Sign-In Client ID
VITE_APPLE_CLIENT_ID=

# ==============================================
# Development
# ==============================================

# Enable debug logging
VITE_DEBUG=false

# Enable React Query Devtools
VITE_ENABLE_DEVTOOLS=true

# ==============================================
# Production
# ==============================================

# Production API URL (override in production)
# VITE_API_BASE_URL=https://api.coredent.com/api/v1

# Production Sentry DSN
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Production Analytics
# VITE_ANALYTICS_ENABLED=true
# VITE_POSTHOG_KEY=your-posthog-key

# ==============================================
# Notes
# ==============================================

# - All VITE_ prefixed variables are exposed to the client
# - Never commit .env file to version control
# - Use .env.local for local overrides
# - Use .env.production for production values
# - Restart dev server after changing environment variables
