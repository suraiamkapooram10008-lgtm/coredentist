# Production Environment Configuration
# Copy this file to .env.production and update with your values

# API Configuration
VITE_API_BASE_URL=https://api.coredent.com

# Environment
VITE_ENV=production

# Feature Flags
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_ANALYTICS=true

# Development Mode (MUST be false in production)
VITE_DEV_BYPASS_AUTH=false

# Monitoring
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# External Services
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx

# Application
VITE_APP_NAME=CoreDent PMS
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@coredent.com

# Security
VITE_ENABLE_CSRF=true
VITE_SESSION_TIMEOUT=3600000

# Performance
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true
